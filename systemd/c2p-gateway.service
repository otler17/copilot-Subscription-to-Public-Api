[Unit]
Description=c2p auth gateway
After=network-online.target c2p-copilot-api.service
PartOf=c2p.target

[Service]
Type=simple
WorkingDirectory=@PROJECT@
ExecStart=@PROJECT@/.venv/bin/python -m uvicorn c2p.app:app --host 127.0.0.1 --port 8787 --log-level warning
Restart=always
RestartSec=3

[Install]
WantedBy=c2p.target
