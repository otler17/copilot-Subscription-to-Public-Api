[Unit]
Description=c2p cloudflared tunnel
After=network-online.target c2p-gateway.service
PartOf=c2p.target

[Service]
Type=simple
WorkingDirectory=@PROJECT@
ExecStart=@PROJECT@/bin/cloudflared tunnel --url http://127.0.0.1:8787 --no-autoupdate
Restart=always
RestartSec=3

[Install]
WantedBy=c2p.target
