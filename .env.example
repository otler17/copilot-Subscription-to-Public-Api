# Defaults — copy to .env and edit if you need.
# All variables are optional; sensible defaults are baked into src/c2p/__init__.py.

# Where the upstream copilot-api listens.
C2P_UPSTREAM=http://127.0.0.1:4141
C2P_UPSTREAM_PORT=4141

# Public gateway bind (keep on 127.0.0.1 — cloudflared connects to it).
C2P_GATEWAY_HOST=127.0.0.1
C2P_GATEWAY_PORT=8787

# Seconds between requests enforced by copilot-api itself.
C2P_RATE_LIMIT=10

# Where keys.sqlite, usage.log, pids/, logs/ live.
C2P_DATA_DIR=./data
